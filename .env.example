# Neon PostgreSQL — pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"

# Neon PostgreSQL — direct connection (used by Prisma migrations only)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
